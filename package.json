{
  "name": "discloud-deploy-action",
  "description": "This action deploys your application to Discloud",
  "version": "1.4.5",
  "main": "dist",
  "license": "Apache-2.0",
  "scripts": {
    "build:test": "tsc --outDir out",
    "package": "ncc build src/index.ts -ms",
    "test": "npm run test:ts && npm run test:lint && npm run build:test && npm run test:node",
    "test:node": "node --test \"**/test/**/*.test.?(c|m)js\"",
    "test:lint": "eslint src",
    "test:ts": "tsc --noEmit",
    "watch": "tsc -w --noEmit"
  },
  "dependencies": {
    "@actions/core": "^2.0.3",
    "@actions/exec": "^2.0.0",
    "@discloudapp/api-types": "^1.1.0",
    "@discloudapp/util": "^1.3.3",
    "bytes": "^3.1.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bytes": "^3.1.5",
    "@types/node": "24",
    "@vercel/ncc": "^0.44.1",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0"
  }
}
